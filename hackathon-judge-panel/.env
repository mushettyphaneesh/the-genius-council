# ===========================================================================
# Hackathon Judge Panel — Environment Variables
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM Provider Keys
# ---------------------------------------------------------------------------

# FEATHERLESS AI (PRIMARY — unlimited tokens, $0 per call)
# Powers ALL Stage 1 + Stage 2 agents (8 of 9 agents).
# Premium plan: $25/month — use promo code BOA26 for $25 free credits.
# Sign up: https://featherless.ai
FEATHERLESS_API_KEY=your-featherless-api-key-here

# AI/ML API (SMART MODEL ONLY — pay-per-token)
# Powers the Head Judge arbitration model ONLY.
# Sign up: https://aimlapi.com
AIMLAPI_API_KEY=your-aimlapi-api-key-here

# Google AI (FALLBACK — only used if AIMLAPI_API_KEY is unset)
GOOGLE_API_KEY=your-google-api-key-here

# GitHub — repo access for repo_analyzer agent
GITHUB_TOKEN=your-github-token-here

# ---------------------------------------------------------------------------
# Band Platform Cloud credentials (for live agents via run_production.py)
# ---------------------------------------------------------------------------
# Register each agent as an "External Agent" at https://app.band.ai/agents
# Copy the Agent UUID and API Key into the fields below.

INTAKE_AGENT_ID=your-intake-agent-id
INTAKE_API_KEY=your-intake-api-key

REPO_ANALYZER_AGENT_ID=your-repo-analyzer-agent-id
REPO_ANALYZER_API_KEY=your-repo-analyzer-api-key

FRAUD_DETECTOR_AGENT_ID=your-fraud-detector-agent-id
FRAUD_DETECTOR_API_KEY=your-fraud-detector-api-key

KG_BUILDER_AGENT_ID=your-kg-builder-agent-id
KG_BUILDER_API_KEY=your-kg-builder-api-key

BUSINESS_JUDGE_AGENT_ID=your-business-judge-agent-id
BUSINESS_JUDGE_API_KEY=your-business-judge-api-key

INNOVATION_JUDGE_AGENT_ID=your-innovation-judge-agent-id
INNOVATION_JUDGE_API_KEY=your-innovation-judge-api-key

BAND_JUDGE_AGENT_ID=your-band-judge-agent-id
BAND_JUDGE_API_KEY=your-band-judge-api-key

DEMO_JUDGE_AGENT_ID=your-demo-judge-agent-id
DEMO_JUDGE_API_KEY=your-demo-judge-api-key

HEAD_JUDGE_AGENT_ID=your-head-judge-agent-id
HEAD_JUDGE_API_KEY=your-head-judge-api-key
